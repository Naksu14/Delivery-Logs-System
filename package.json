{
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd dls-backend && npm run start:dev",
    "start:frontend": "cd dls-frontend && npm run dev",
    "build": "concurrently \"npm run build:backend\" \"npm run build:frontend\"",
    "build:backend": "cd dls-backend && npm run build",
    "build:frontend": "cd dls-frontend && npm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2"
  }
}
